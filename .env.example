# =============================================================================
# myanmardev.com — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Worker API
# -----------------------------------------------------------------------------
# The Cloudflare Worker that proxies DNS management requests.
# Used by the Subdomain Builder to check availability and create DNS records.
# Default: https://subdomain-api.myanmardev.com
PUBLIC_WORKER_API_URL=https://subdomain-api.myanmardev.com

# -----------------------------------------------------------------------------
# Firebase Configuration (Web App / Client-Side)
# -----------------------------------------------------------------------------
# These PUBLIC_ vars are exposed in the browser — they are NOT secret.
# Get them from: Firebase Console -> Project Settings -> General -> Your apps -> Web app
#
# Used for:
#   - Firebase Authentication (GitHub + Google sign-in)
#   - Firestore reads/writes (user profiles, orders, redeem codes)
#   - Analytics (Measurement ID)
# -----------------------------------------------------------------------------

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
PUBLIC_FIREBASE_MEASUREMENT_ID=

# =============================================================================
# SYSTEM OVERVIEW
# =============================================================================
#
# DUAL AUTHENTICATION
# -------------------
# The app supports two sign-in providers via Firebase Auth:
#   1. GitHub OAuth — legacy system, uses approved_users collection for access control
#   2. Google OAuth — standard Firebase auth, no approval needed
#
# Both providers create a user profile in the Firestore "users" collection on
# first sign-in. The profile tracks the auth provider, token balance, and
# GitHub username (if applicable).
#
# TOKEN SYSTEM
# ------------
# Authenticated users have a token balance stored in Firestore (users/{uid}.tokenBalance).
# Tokens are used to purchase products/services:
#   - Subdomain DNS records
#   - Website builds
#   - Portfolio pages
#
# Tokens can be acquired via:
#   1. Token purchase orders (admin-approved, see scripts/add-tokens.mjs)
#   2. Redeem codes (see scripts/create-redeem-code.mjs)
#   3. Admin grants (see scripts/add-tokens.mjs)
#
# Token packages (defined in src/lib/orders.ts):
#   Starter  —  5 tokens / $2.50
#   Basic    — 10 tokens / $4.00
#   Pro      — 25 tokens / $8.00
#   Business — 50 tokens / $12.00
#
# PUBLIC vs AUTHENTICATED FEATURES
# --------------------------------
# Public (no login required):
#   - Homepage, hero, pricing info
#   - Subdomain availability check
#   - Product catalog browsing
#   - approved_users read (for legacy auth check)
#
# Authenticated (login required):
#   - Token balance display
#   - Token purchase
#   - Redeem codes
#   - Subdomain creation (deducts tokens)
#   - Order history
#   - Dashboard
#
# FIRESTORE COLLECTIONS
# ---------------------
#   users          — User profiles with token balance
#   approved_users — Legacy GitHub approval list (read: public, write: admin only)
#   orders         — Token purchases and product orders
#   redeemCodes    — Promotional codes for free tokens
#   userRedeems    — Redemption history per user
#   products       — Product catalog (read: public, write: admin only)
#
# ADMIN SCRIPTS (scripts/)
# -------------------------
# All scripts read Firebase config from this .env file.
#
#   approve-user.mjs     — Manage the approved_users collection
#     node scripts/approve-user.mjs add <github-username>
#     node scripts/approve-user.mjs remove <github-username>
#     node scripts/approve-user.mjs list
#
#   add-tokens.mjs       — Add tokens to a user or approve an order
#     node scripts/add-tokens.mjs --email user@example.com --tokens 10
#     node scripts/add-tokens.mjs --uid <firebase-uid> --tokens 10
#     node scripts/add-tokens.mjs --order-id <order-id> --approve
#
#   create-redeem-code.mjs — Create promotional redeem codes
#     node scripts/create-redeem-code.mjs --code WELCOME --tokens 5 --max-uses 100
#     node scripts/create-redeem-code.mjs --code LAUNCH --tokens 10 --max-uses 50 --expires 2026-12-31
#
#   list-users.mjs       — List all users with token balances
#     node scripts/list-users.mjs
#     node scripts/list-users.mjs --export users.csv
#
# GITHUB ACTIONS (CI/CD)
# ----------------------
# These PUBLIC_ vars are injected at build time via GitHub Actions Variables
# (NOT Secrets — they are not sensitive).
#
# Set them at:
#   https://github.com/vibecode-ting/myanmardev.com/settings/variables/actions
#
# The deploy workflow (.github/workflows/deploy.yml) reads them and passes
# them as env vars during `pnpm build`. See GITHUB_SECRETS_GUIDE.md for details.
# =============================================================================
