---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import App from '../../components/App';
import { t, type Language } from '../../i18n/utils';
const lang: Language = 'my';
const title = 'myanmardev.com — သင့် Subdomain။ ၃၀ စက္ကန့်အတွင်း Live။';
const description = 'Coding မလို။ စောင့်ရန်မလို။ ချက်ချင်း deploy။ မြန်မာ developer များအတွက်။';
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <App client:load />

  <!-- Contact -->
  <section id="contact" style={{
    padding: 'clamp(3rem,8vw,5rem) clamp(1.25rem,4vw,3rem)',
    borderTop: '1px solid var(--border)',
    textAlign: 'center',
  }}>
    <h2 style={{
      fontFamily: 'var(--display)',
      fontSize: 'clamp(1.5rem,3vw,2rem)',
      fontWeight: 600,
      color: 'var(--ink)',
      marginBottom: '1rem',
    }}>
      ဆက်သွယ်ရန်
    </h2>
    <a
      href="mailto:hello@myanmardev.com"
      className="btn"
      style={{ padding: '1rem 2rem' }}
    >
      hello@myanmardev.com
    </a>
  </section>

  <!-- Footer -->
  <footer style={{
    borderTop: '1px solid var(--border)',
    background: 'var(--surface)',
    padding: 'clamp(2rem, 4vw, 3rem) clamp(1.25rem,4vw,3rem)',
  }}>
    <div style={{
      maxWidth: '78rem',
      margin: '0 auto',
      display: 'flex',
      flexWrap: 'wrap',
      justifyContent: 'space-between',
      alignItems: 'center',
      gap: '1rem',
    }}>
      <div>
        <a href="/" style={{
          fontFamily: 'var(--display)',
          fontWeight: 700,
          fontSize: '1rem',
          letterSpacing: '-0.02em',
        }}>
          <span style={{ color: 'var(--accent)' }}>myanmardev</span>.com
        </a>
      </div>
      <div style={{
        display: 'flex',
        alignItems: 'center',
        gap: '0.5rem',
      }}>
        <span style={{
          fontFamily: 'var(--mono)',
          fontSize: '0.625rem',
          color: 'var(--muted)',
          letterSpacing: '0.02em',
        }}>
          {t(lang, 'footer.rights')} · {t(lang, 'footer.built')}
        </span>
        <span class="dot" style={{ width: '5px', height: '5px' }}></span>
      </div>
    </div>
  </footer>
</Layout>
