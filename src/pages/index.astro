---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Products from '../components/Products.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductsComingSoon from '../components/ProductsComingSoon.astro';
import Pricing from '../components/Pricing.astro';
import { t, type Language } from '../i18n/utils';
const lang: Language = 'en';
const title = 'myanmardev.com — Build & Deploy Instantly';
const description = 'Automated web services for Myanmar developers. Get your own .myanmardev.com subdomain, build websites, and deploy instantly. No credit card required.';
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <HowItWorks />
    <Products />
    <ProductCard />
    <ProductsComingSoon />
    <Pricing />

    <!-- Contact Us -->
    <section id="contact" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);text-align:center;border-top:1px solid #1D232B">
      <div class="sx rise" style="justify-content:center"><b></b> <span>/ contact</span></div>
      <h2 class="h-section rise" style="margin-top:.9rem">Get in touch</h2>
      <p class="lede rise" style="margin:.6rem auto 0">Questions, custom requests, or partnership inquiries? Reach us directly.</p>
      <a class="btn rise" style="margin-top:1.5rem;padding:1rem 2.4rem" href="mailto:hello@myanmardev.com">hello@myanmardev.com</a>
    </section>
  </main>

  <footer style="border-top:1px solid #1D232B;background:color-mix(in srgb,var(--wash) 50%,transparent)">
    <div style="max-width:78rem;margin:0 auto;padding:clamp(2rem,4vw,3rem) clamp(1.25rem,4vw,3rem);display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem">
      <div>
        <a href="/" style="font-family:var(--display);font-weight:600;font-size:1.1rem;letter-spacing:-.02em">
          <span style="color:var(--accent)">myanmardev</span>.com
        </a>
        <p class="mono" style="color:color-mix(in srgb,var(--ink) 55%,transparent);font-size:.6875rem;margin-top:.4rem;max-width:22rem">
          {t(lang, 'footer.desc')}
        </p>
      </div>
      <div style="display:flex;align-items:center;gap:.5rem" class="mono">
        <span style="color:color-mix(in srgb,var(--ink) 62%,transparent);font-size:.6875rem">&copy; {new Date().getFullYear()} {t(lang, 'footer.built')}</span>
        <span class="dot" style="width:6px;height:6px"></span>
      </div>
    </div>
  </footer>
</Layout>
