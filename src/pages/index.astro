---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Products from '../components/Products.astro';
import Pricing from '../components/Pricing.astro';
import Testimonials from '../components/Testimonials.astro';
import CTA from '../components/CTA.astro';
import { t, type Language } from '../i18n/utils';
const lang: Language = 'en';
const title = 'myanmardev.com — Your Subdomain. Live in 30 Seconds.';
const description = 'Zero Config. True Serverless. Instant Production. Automated web services for Myanmar developers.';
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <Hero lang={lang} />
  <HowItWorks lang={lang} />
  <Products lang={lang} />
  <Pricing lang={lang} />
  <Testimonials lang={lang} />
  <CTA lang={lang} />

  <!-- Footer -->
  <footer style={{
    borderTop: '1px solid var(--border)',
    background: 'var(--surface)',
    padding: 'clamp(2rem, 4vw, 3rem) clamp(1.25rem, 4vw, 3rem)',
  }}>
    <div style={{
      maxWidth: '78rem',
      margin: '0 auto',
      display: 'flex',
      flexWrap: 'wrap',
      justifyContent: 'space-between',
      alignItems: 'center',
      gap: '1rem',
    }}>
      <div>
        <a href="/" style={{
          fontFamily: 'var(--display)',
          fontWeight: 700,
          fontSize: '1rem',
          letterSpacing: '-0.02em',
        }}>
          <span style={{ color: 'var(--accent)' }}>myanmardev</span>.com
        </a>
      </div>
      <div style={{
        display: 'flex',
        alignItems: 'center',
        gap: '0.5rem',
      }}>
        <span style={{
          fontFamily: 'var(--mono)',
          fontSize: '0.625rem',
          color: 'var(--muted)',
          letterSpacing: '0.02em',
        }}>
          {t(lang, 'footer.rights')} · {t(lang, 'footer.built')}
        </span>
        <span class="dot" style={{ width: '5px', height: '5px' }}></span>
      </div>
    </div>
  </footer>
</Layout>
