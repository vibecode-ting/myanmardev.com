---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import App from '../components/App';
import { t, type Language } from '../i18n/utils';
const lang: Language = 'en';
const title = 'myanmardev.com — Your Subdomain. Live in 30 Seconds.';
const description = 'No coding. No waiting. Just deploy. Automated web services for Myanmar developers.';
---

<Layout title={title} description={description} lang={lang}>
  <Header lang={lang} />
  <App client:load />

  <!-- Contact -->
  <section id="contact" style={{
    padding: 'clamp(3rem,8vw,5rem) clamp(1.25rem,4vw,3rem)',
    borderTop: '1px solid #1D232B',
    textAlign: 'center',
  }}>
    <h2 style={{
      fontFamily: 'var(--display)',
      fontSize: 'clamp(1.5rem,3vw,2rem)',
      fontWeight: 600,
      color: 'var(--ink)',
      marginBottom: '1rem',
    }}>
      Get in Touch
    </h2>
    <a
      href="mailto:hello@myanmardev.com"
      className="btn"
      style={{ padding: '1rem 2rem' }}
    >
      hello@myanmardev.com
    </a>
  </section>

  <!-- Footer -->
  <footer style={{
    borderTop: '1px solid #1D232B',
    background: 'color-mix(in srgb, var(--wash) 50%, transparent)',
    padding: '2rem clamp(1.25rem,4vw,3rem)',
    textAlign: 'center',
  }}>
    <a href="/" style={{
      fontFamily: 'var(--display)',
      fontWeight: 600,
      fontSize: '1.1rem',
      letterSpacing: '-0.02em',
    }}>
      <span style={{ color: 'var(--accent)' }}>myanmardev</span>.com
    </a>
    <p style={{
      fontFamily: 'var(--mono)',
      fontSize: '0.75rem',
      color: 'var(--muted)',
      marginTop: '0.5rem',
    }}>
      {t(lang, 'footer.rights')} · {t(lang, 'footer.built')}
    </p>
  </footer>
</Layout>
