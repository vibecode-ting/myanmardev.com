---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
---

<Layout title={`${t(lang, 'auth.signIn')} | myanmardev.com`} description="Sign in to myanmardev.com with Google or GitHub">
  <Header lang={lang} />

  <main class="signin-page">
    <div class="signin-card">
      <a href="/" class="signin-logo">
        <span style="color:var(--accent)">myanmardev</span>.com
      </a>

      <h1 class="signin-title">{t(lang, 'auth.title')}</h1>
      <div style="width:2rem;height:1px;background:var(--accent);margin:0.75rem 0"></div>

      <div class="signin-buttons">
        <button id="btn-google" class="signin-btn">
          <svg width="16" height="16" viewBox="0 0 24 24">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          {t(lang, 'auth.google')}
        </button>

        <button id="btn-github" class="signin-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          {t(lang, 'auth.github')}
        </button>
      </div>

      <div id="signin-error" class="signin-error" style="display:none">
        <span id="signin-error-text"></span>
      </div>

      <p class="signin-footer">{t(lang, 'auth.terms')}</p>
    </div>
  </main>
</Layout>

<style>
  .signin-page {
    min-height: calc(100vh - 3rem);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem clamp(1.25rem, 4vw, 3rem);
  }

  .signin-card {
    border: 1px solid var(--rule);
    padding: 2.5rem 2rem;
    max-width: 380px;
    width: 100%;
  }

  .signin-logo {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    display: block;
    margin-bottom: 2rem;
    text-decoration: none;
    color: inherit;
  }

  .signin-title {
    font-family: var(--display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .signin-buttons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1.5rem;
  }

  .signin-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    width: 100%;
    border: 1px solid var(--ink);
    background: transparent;
    color: var(--ink);
    border-radius: 0;
  }

  .signin-btn:hover {
    background: var(--ink);
    color: var(--base);
  }

  .signin-error {
    margin-top: 1rem;
    padding: 0.75rem 1rem;
    border: 1px solid #ef4444;
    font-family: var(--mono);
    font-size: 0.75rem;
    color: #ef4444;
  }

  .signin-footer {
    font-family: var(--mono);
    font-size: 0.625rem;
    color: var(--muted);
    margin: 1.5rem 0 0;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
</style>

<script is:inline>
  (function() {
    var btnGoogle = document.getElementById('btn-google');
    var btnGithub = document.getElementById('btn-github');
    var errorDiv = document.getElementById('signin-error');
    var errorText = document.getElementById('signin-error-text');

    function showError(msg) {
      errorText.textContent = msg;
      errorDiv.style.display = 'block';
    }

    function hideError() {
      errorDiv.style.display = 'none';
    }

    async function handleSignIn(provider) {
      hideError();
      btnGoogle.disabled = true;
      btnGithub.disabled = true;

      try {
        var fb = await import('/src/lib/firebase.ts');
        var authMod = await import('/src/lib/auth.ts');
        var firebaseAuth = await import('firebase/auth');

        var auth = fb.getAuthInstance();
        var authProvider = provider === 'google'
          ? fb.getGoogleProvider()
          : fb.getGithubProvider();

        var result = await firebaseAuth.signInWithPopup(auth, authProvider);

        if (result.user) {
          await authMod.createOrUpdateUserProfile(result.user);
          window.location.href = '/my';
        }
      } catch (err) {
        console.error('Sign-in error:', err);
        var msg = 'Sign-in failed. Please try again.';
        if (err.code === 'auth/popup-closed-by-user') {
          msg = 'Sign-in cancelled.';
        } else if (err.code === 'auth/popup-blocked') {
          msg = 'Popup blocked. Allow popups and retry.';
        } else if (err.code === 'auth/network-request-failed') {
          msg = 'Network error. Check connection.';
        } else if (err.message) {
          msg = err.message;
        }
        showError(msg);
      } finally {
        btnGoogle.disabled = false;
        btnGithub.disabled = false;
      }
    }

    btnGoogle.addEventListener('click', function() { handleSignIn('google'); });
    btnGithub.addEventListener('click', function() { handleSignIn('github'); });
  })();
</script>
