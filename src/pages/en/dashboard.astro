---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import AuthProvider from '../../components/AuthProvider';
import DashboardContent from '../../components/DashboardContent';
import { t, type Language } from '../../i18n/utils';
const lang: Language = 'en';
const title = 'Dashboard — myanmardev.com';
const description = 'Manage your tokens, view order history, and track your deployments.';
---

<Layout title={title} description={description} lang={lang}>
  <AuthProvider client:load>
    <Header lang={lang} />
    <main style="padding:clamp(2rem,5vw,4rem) clamp(1.25rem,4vw,3rem)">
      <div style="max-width:78rem;margin:0 auto">
        <div class="sx rise"><b></b> <span>/ dashboard</span></div>
        <h1 class="h-section rise" style="margin-top:.9rem">Your Dashboard</h1>
        <p class="lede rise" style="margin:.6rem auto 0;max-width:600px">
          Manage your tokens, view order history, and track your deployments.
        </p>

        <DashboardContent client:load />
      </div>
    </main>
  </AuthProvider>

  <footer style="border-top:1px solid #1D232B;background:color-mix(in srgb,var(--wash) 50%,transparent);margin-top:4rem">
    <div style="max-width:78rem;margin:0 auto;padding:clamp(2rem,4vw,3rem) clamp(1.25rem,4vw,3rem);display:flex;flex-wrap:wrap;justify-content:space-between;align-items:center;gap:1rem">
      <div>
        <a href="/" style="font-family:var(--display);font-weight:600;font-size:1.1rem;letter-spacing:-.02em">
          <span style="color:var(--accent)">myanmardev</span>.com
        </a>
        <p class="mono" style="color:color-mix(in srgb,var(--ink) 55%,transparent);font-size:.6875rem;margin-top:.4rem;max-width:22rem">
          {t(lang, 'footer.desc')}
        </p>
      </div>
      <div style="display:flex;align-items:center;gap:.5rem" class="mono">
        <span style="color:color-mix(in srgb,var(--ink) 62%,transparent);font-size:.6875rem">&copy; {new Date().getFullYear()} {t(lang, 'footer.built')}</span>
        <span class="dot" style="width:6px;height:6px"></span>
      </div>
    </div>
  </footer>
</Layout>
