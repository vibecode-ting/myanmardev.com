---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

import '@fontsource/noto-sans-myanmar/400.css';
import '@fontsource/noto-sans-myanmar/600.css';
import '@fontsource/noto-sans-myanmar/700.css';

const { title, description, lang = 'en' } = Astro.props;
const siteUrl = 'https://app.myanmardev.com';
const metaDescription = description || 'Subdomain Register — automated DNS and web services for Myanmar developers. Get your own .myanmardev.com subdomain in seconds. No waiting, no hassle.';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#d97706" />
    <meta name="color-scheme" content="light dark" />

    <!-- Prevent flash: apply stored theme before paint -->
    <script is:inline>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content="myanmardev.com" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />

    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts: system stack + Noto Sans Myanmar (self-hosted) -->
  </head>
  <body>
    <slot />
    <!-- Single theme toggle handler for all .theme-toggle buttons -->
    <script is:inline>
      (function () {
        function apply(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);
        }
        document.addEventListener('click', function (e) {
          var btn = e.target.closest('.theme-toggle');
          if (!btn) return;
          var next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          apply(next);
        });
      })();
    </script>
    <noscript><style>.rise{opacity:1!important;transform:none!important}</style></noscript>
    <script>
      const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target)}}),{threshold:.12});
      document.querySelectorAll(".rise").forEach((el,i)=>{el.style.transitionDelay=Math.min(i%4*70,210)+"ms";io.observe(el)});
    </script>
  </body>
</html>

<style is:global>
  /* ─── Myanmardev Design Tokens (amber/gold) ─── */
  :root {
    --base: #F4F2ED;
    --surface: #FFFFFF;
    --ink: #141414;
    --accent: #d97706;
    --accent-dim: #b45309;
    --muted: #6B7280;
    --wash: #EAE7DF;
    --rule: #D6D2C8;
    --border: #D6D2C8;
    --border-accent: color-mix(in srgb, var(--accent) 30%, transparent);
    --glow: transparent;
    --display: Georgia, 'Times New Roman', serif;
    --body: system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    --mono: 'SFMono-Regular', Menlo, Consolas, 'Liberation Mono', monospace;
  }

  [data-theme='dark'] {
    --base: #141414;
    --surface: #1a1a1a;
    --ink: #F4F2ED;
    --accent: #d97706;
    --accent-dim: #f59e0b;
    --muted: #8a8a8a;
    --wash: #1e1e1e;
    --rule: #2a2a2a;
    --border: #2a2a2a;
    --border-accent: color-mix(in srgb, var(--accent) 30%, transparent);
    --glow: transparent;
  }

  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--base);
    color: var(--ink);
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.75;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  /* Burmese language: Noto Sans Myanmar */
  html[lang="my"] body,
  html[lang="my"] .btn,
  html[lang="my"] .mono,
  html[lang="my"] .eyebrow,
  html[lang="my"] .sx {
    font-family: 'Noto Sans Myanmar', system-ui, sans-serif;
    line-height: 1.9;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--accent);
  }

  ::selection {
    background: var(--accent);
    color: var(--base);
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ─── Type scale ─── */
  .h-display {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
  }

  .h-section {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .mono {
    font-family: var(--mono);
    font-size: 0.875rem;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .lede {
    color: var(--muted);
    max-width: 68ch;
    font-size: 1rem;
    line-height: 1.75;
  }

  /* ─── Section index ─── */
  body { counter-reset: tg-sx; }
  .sx {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }
  .sx b { font-weight: 700; }
  .sx b::before {
    counter-increment: tg-sx;
    content: counter(tg-sx, decimal-leading-zero);
  }
  .sx span {
    color: var(--muted);
    font-weight: 500;
  }
  .sx::after {
    content: "";
    flex: 0 0 auto;
    width: clamp(2rem, 8vw, 5rem);
    height: 1px;
    background: var(--rule);
    align-self: center;
  }

  /* ─── 1px Rule system ─── */
  .rule-top { border-top: 1px solid var(--rule); }
  .rule-bottom { border-bottom: 1px solid var(--rule); }
  .rule-y { border-top: 1px solid var(--rule); border-bottom: 1px solid var(--rule); }

  /* ─── Buttons (Brutalist: zero radius, mono uppercase) ─── */
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--accent);
    color: var(--base);
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    padding: 0.875rem 1.5rem;
    border-radius: 0;
    border: 1px solid var(--accent);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .btn:hover {
    background: var(--ink);
    color: var(--base);
    border-color: var(--ink);
  }
  .btn:active { opacity: 0.9; }

  .btn--ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
  }
  .btn--ghost:hover {
    background: var(--ink);
    color: var(--base);
  }

  /* ─── Ruled rows (replaces cards) ─── */
  .ruled-row {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    transition: background 0.15s ease;
  }
  .ruled-row:hover {
    background: var(--wash);
  }

  /* ─── Stat block ─── */
  .stat-block {
    display: grid;
    gap: 0;
  }
  .stat-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .stat-label {
    font-family: var(--mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--ink) 55%, transparent);
  }
  .stat-value {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.875rem;
    text-align: right;
  }

  /* ─── Rise entrance ─── */
  .rise {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .rise.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rise { opacity: 1; transform: none; transition: none; }
  }

  /* ─── Auth gating ─── */
  body:not([data-auth="signed-in"]) .auth-only { display: none; }
  body[data-auth="signed-in"] .auth-only { display: unset; }
  body[data-auth="signed-in"] .anon-only { display: none; }
  body:not([data-auth="signed-in"]) .anon-only { display: unset; }

  .gate-fallback-card {
    padding: 2.5rem 1.5rem;
    text-align: center;
    border: 1px solid var(--rule);
    background: var(--surface);
    max-width: 520px;
    margin: 0 auto;
  }
  .gate-fallback-card .gate-fallback-heading {
    font-family: var(--mono);
    font-size: .6875rem;
    color: var(--accent);
    margin-bottom: .8rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    font-weight: 600;
  }
  .gate-fallback-card .gate-fallback-text {
    color: var(--muted);
    font-size: .875rem;
    margin: 0;
    line-height: 1.75;
  }
</style>
