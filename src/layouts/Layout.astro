---
interface Props {
  title: string;
  description?: string;
  lang?: string;
}

const { title, description, lang = 'en' } = Astro.props;
const siteUrl = 'https://app.myanmardev.com';
const metaDescription = description || 'Subdomain Register — automated DNS and web services for Myanmar developers. Get your own .myanmardev.com subdomain in seconds. No waiting, no hassle.';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#00D4AA" />
    <meta name="color-scheme" content="dark light" />

    <!-- Prevent flash: apply stored theme before paint -->
    <script>
      (function() {
        var t = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:site_name" content="myanmardev.com" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />

    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts: Space Grotesk (display), Inter (body), JetBrains Mono (terminal) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <noscript><style>.rise{opacity:1!important;transform:none!important}</style></noscript>
    <script>
      const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target)}}),{threshold:.12});
      document.querySelectorAll(".rise").forEach((el,i)=>{el.style.transitionDelay=Math.min(i%4*70,210)+"ms";io.observe(el)});
    </script>
  </body>
</html>

<style is:global>
  :root {
    --base: #08090A;
    --surface: #0F1117;
    --ink: #E2E8F0;
    --accent: #00D4AA;
    --accent-dim: #00B894;
    --muted: #5A6578;
    --wash: #0F1117;
    --border: #1A1F2E;
    --border-accent: color-mix(in srgb, var(--accent) 30%, transparent);
    --glow: rgba(0, 212, 170, 0.08);
    --display: 'Space Grotesk', sans-serif;
    --body: 'Inter', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  [data-theme='dark'] {
    --base: #08090A;
    --surface: #0F1117;
    --ink: #E2E8F0;
    --accent: #00D4AA;
    --accent-dim: #00B894;
    --muted: #5A6578;
    --wash: #0F1117;
    --border: #1A1F2E;
    --border-accent: color-mix(in srgb, var(--accent) 30%, transparent);
    --glow: rgba(0, 212, 170, 0.08);
  }

  [data-theme='light'] {
    --base: #FAFBFC;
    --surface: #FFFFFF;
    --ink: #0F1117;
    --accent: #00A88A;
    --accent-dim: #008F75;
    --muted: #6B7280;
    --wash: #F3F4F6;
    --border: #E5E7EB;
    --border-accent: color-mix(in srgb, var(--accent) 25%, transparent);
    --glow: rgba(0, 168, 138, 0.06);
    --display: 'Space Grotesk', sans-serif;
    --body: 'Inter', system-ui, sans-serif;
    --mono: 'JetBrains Mono', monospace;
  }

  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--base);
    color: var(--ink);
    font-family: var(--body);
    font-size: 0.9375rem;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  img {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ::selection {
    background: var(--accent);
    color: var(--base);
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* ─── Type scale ─── */
  .h-display {
    font-family: var(--display);
    font-weight: 700;
    font-size: clamp(2.4rem, 5.8vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.035em;
  }

  .h-section {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .mono {
    font-family: var(--mono);
    font-size: 0.8125rem;
  }

  .eyebrow {
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .lede {
    color: var(--muted);
    max-width: 32rem;
    font-size: 1rem;
    line-height: 1.65;
  }

  /* ─── Section index ─── */
  body { counter-reset: tg-sx; }
  .sx {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .sx b { font-weight: 700; }
  .sx b::before {
    counter-increment: tg-sx;
    content: counter(tg-sx, decimal-leading-zero);
  }
  .sx span {
    color: var(--muted);
    font-weight: 500;
  }
  .sx::after {
    content: "";
    flex: 0 0 auto;
    width: clamp(2rem, 8vw, 5rem);
    height: 1px;
    background: var(--border-accent);
    align-self: center;
  }

  /* ─── Live status dot ─── */
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    display: inline-block;
    animation: pulse 2.4s ease-in-out infinite;
    box-shadow: 0 0 8px var(--accent);
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent); }
    50% { opacity: 0.6; box-shadow: 0 0 2px var(--accent); }
  }

  /* ─── Buttons ─── */
  .btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--accent);
    color: var(--base);
    font-family: var(--mono);
    font-weight: 600;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.75rem 1.4rem;
    border-radius: 6px;
    border: 0;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .btn::before {
    content: "";
    width: 5px;
    height: 5px;
    border-left: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    opacity: 0.7;
  }
  .btn::after {
    content: "";
    width: 5px;
    height: 5px;
    border-right: 1.5px solid currentColor;
    border-top: 1.5px solid currentColor;
    opacity: 0.7;
  }
  .btn:hover {
    background: var(--accent-dim);
    box-shadow: 0 0 20px var(--glow), 0 4px 12px rgba(0,0,0,0.3);
    transform: translateY(-1px);
  }
  .btn:active { transform: scale(0.98) translateY(0); }

  .btn--ghost {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--border);
  }
  .btn--ghost::before, .btn--ghost::after { border-color: var(--accent); }
  .btn--ghost:hover {
    border-color: var(--accent);
    background: var(--glow);
    box-shadow: 0 0 16px var(--glow);
  }

  /* ─── Panels ─── */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .panel:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 24px var(--glow);
  }
  .panel .ph {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  /* ─── Terminal block ─── */
  .term {
    background: #08090A;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    font-family: var(--mono);
    font-size: 0.8125rem;
    line-height: 1.75;
  }
  .term .bar {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    border-bottom: 1px solid var(--border);
  }
  .term .bar i {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: #1A1F2E;
  }
  .term pre {
    padding: 1rem 1.1rem;
    overflow-x: auto;
    color: color-mix(in srgb, var(--ink) 80%, transparent);
  }
  .term .c { color: var(--muted); }
  .term .g { color: var(--accent); }
  .term .y { color: #E8A33D; }

  /* ─── Corner ticks ─── */
  .ticks { position: relative; }
  .ticks::before, .ticks::after {
    content: "+";
    position: absolute;
    font-family: var(--mono);
    color: var(--muted);
    font-size: 0.875rem;
    opacity: 0.4;
  }
  .ticks::before { top: -10px; left: -10px; }
  .ticks::after { bottom: -10px; right: -10px; }

  /* ─── Number/metric style ─── */
  .num {
    font-family: var(--mono);
    font-variant-numeric: tabular-nums;
  }

  /* ─── Rise entrance ─── */
  .rise {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .rise.in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .rise { opacity: 1; transform: none; transition: none; }
    .dot { animation: none; }
  }

  /* ─── Auth gating ─── */
  body:not([data-auth="signed-in"]) .auth-only { display: none; }
  body[data-auth="signed-in"] .auth-only { display: unset; }
  body[data-auth="signed-in"] .anon-only { display: none; }
  body:not([data-auth="signed-in"]) .anon-only { display: unset; }

  .gate-fallback-card {
    padding: 2.5rem 1.5rem;
    text-align: center;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--surface);
    max-width: 520px;
    margin: 0 auto;
  }
  .gate-fallback-card .gate-fallback-icon {
    font-size: 1.6rem;
    margin-bottom: .5rem;
  }
  .gate-fallback-card .gate-fallback-heading {
    font-family: var(--mono);
    font-size: .6875rem;
    color: var(--accent);
    margin-bottom: .8rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    font-weight: 600;
  }
  .gate-fallback-card .gate-fallback-text {
    color: var(--muted);
    font-size: .875rem;
    margin: 0;
    line-height: 1.7;
  }
</style>
