---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const tiers = ['starter', 'basic', 'pro', 'business'] as const;
---

<section id="pricing" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-top:1px solid var(--border)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise" style="justify-content:center"><b></b> <span>{t(lang, 'pricing.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.9rem;text-align:center">{t(lang, 'pricing.heading')}</h2>
    <p class="lede rise" style="margin:.6rem auto 0;text-align:center;max-width:600px">
      {t(lang, 'pricing.sub')}
    </p>

    <!-- Token Packages -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;margin-top:2.5rem">
      {tiers.map((tier) => {
        const isPro = tier === 'pro';
        return (
          <div class:list={['pricing-card', 'rise']} style={`padding:1.75rem;background:var(--surface);border:${isPro ? '1.5px solid var(--accent)' : '1px solid var(--border)'};border-radius:10px;text-align:center;position:relative`}>
            {isPro && (
              <div style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:var(--accent);color:var(--base);font-family:var(--mono);font-size:0.625rem;font-weight:700;padding:3px 10px;border-radius:4px;text-transform:uppercase;letter-spacing:0.06em">
                {t(lang, 'pricing.popular')}
              </div>
            )}
            <div style={`font-family:var(--mono);font-size:0.6875rem;font-weight:600;color:${isPro ? 'var(--accent)' : 'var(--muted)'};text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.5rem`}>
              {t(lang, `pricing.${tier}.name`)}
            </div>
            <div style="font-family:var(--display);font-size:2.25rem;font-weight:700;color:var(--ink);margin-bottom:0.15rem;letter-spacing:-0.03em">
              {t(lang, `pricing.${tier}.tokens`)}
            </div>
            <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1rem;text-transform:uppercase;letter-spacing:0.06em">
              Tokens
            </div>
            <!-- Dual currency: USD + MMK -->
            <div style="font-family:var(--display);font-size:1.375rem;font-weight:700;color:var(--accent);margin-bottom:0.15rem">
              {t(lang, `pricing.${tier}.usd`)}
            </div>
            <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1.25rem">
              {t(lang, `pricing.${tier}.mmk`)}
            </div>
            <a href="#product" class:list={['btn', { 'btn--ghost': !isPro }]} style="width:100%;justify-content:center;padding:0.7rem;display:inline-flex">
              {t(lang, 'pricing.buy')}
            </a>
          </div>
        );
      })}
    </div>

    <!-- Redeem Codes -->
    <div class="rise" style="margin-top:2rem;padding:1.75rem;background:var(--glow);border:1px solid var(--border-accent);border-radius:10px;text-align:center">
      <div style="font-size:1.5rem;margin-bottom:0.5rem">🎟️</div>
      <h3 style="font-family:var(--display);font-size:1.0625rem;font-weight:600;color:var(--ink);margin:0 0 0.4rem;letter-spacing:-0.01em">
        Have a Promo Code?
      </h3>
      <p style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);margin:0 0 1rem;line-height:1.6">
        Sign in and redeem your code for free tokens. No credit card required.
      </p>
      <a href="#" class="btn btn--ghost" style="padding:0.7rem 1.4rem" onclick="document.querySelector('[data-redeem-button]')?.click()">
        Redeem Code
      </a>
    </div>
  </div>
</section>

<style>
  .pricing-card {
    transition: all 0.2s ease;
  }

  .pricing-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 24px var(--glow), 0 12px 32px rgba(0,0,0,0.3);
    border-color: var(--border-accent) !important;
  }
</style>
