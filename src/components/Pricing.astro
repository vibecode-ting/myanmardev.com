---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const tiers = ['starter', 'basic', 'pro', 'business'] as const;
---

<section id="pricing" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise"><b></b> <span>{t(lang, 'pricing.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.75rem">{t(lang, 'pricing.heading')}</h2>
    <p class="lede rise" style="margin-top:.4rem">{t(lang, 'pricing.sub')}</p>

    <!-- Token Packages as ruled rows -->
    <div class="pricing-table rise">
      <div class="pricing-header">
        <span>Package</span>
        <span>Tokens</span>
        <span>USD</span>
        <span>MMK</span>
        <span></span>
      </div>
      {tiers.map((tier) => {
        const isPro = tier === 'pro';
        return (
          <div class:list={['pricing-row', { 'pricing-row--highlight': isPro }]}>
            <span class="pricing-tier">
              {t(lang, `pricing.${tier}.name`)}
              {isPro && <span class="pricing-badge">{t(lang, 'pricing.popular')}</span>}
            </span>
            <span class="pricing-tokens">{t(lang, `pricing.${tier}.tokens`)}</span>
            <span class="pricing-usd">{t(lang, `pricing.${tier}.usd`)}</span>
            <span class="pricing-mmk">{t(lang, `pricing.${tier}.mmk`)}</span>
            <a href="#product" class:list={['btn', 'btn--ghost', { 'btn': isPro }]} style="padding:0.5rem 1rem;font-size:0.625rem">
              {t(lang, 'pricing.buy')}
            </a>
          </div>
        );
      })}
    </div>

    <!-- Redeem Codes -->
    <div class="rise" style="margin-top:2rem;padding:1.5rem 0;border-top:1px solid var(--rule)">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
        <div>
          <h3 style="font-family:var(--display);font-size:1rem;font-weight:700;color:var(--ink);margin:0 0 0.15rem">
            Have a Promo Code?
          </h3>
          <p style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);margin:0">
            Sign in and redeem for free tokens.
          </p>
        </div>
        <a href="#" class="btn btn--ghost" style="padding:0.5rem 1rem" onclick="document.querySelector('[data-redeem-button]')?.click()">
          Redeem Code
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .pricing-table {
    margin-top: 2rem;
  }

  .pricing-header {
    display: grid;
    grid-template-columns: 1.5fr 0.75fr 0.75fr 1fr auto;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--ink);
    font-family: var(--mono);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: color-mix(in srgb, var(--ink) 55%, transparent);
  }

  .pricing-row {
    display: grid;
    grid-template-columns: 1.5fr 0.75fr 0.75fr 1fr auto;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: center;
    transition: background 0.15s ease;
  }

  .pricing-row:hover {
    background: var(--wash);
  }

  .pricing-row--highlight {
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }

  .pricing-tier {
    font-family: var(--mono);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .pricing-badge {
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    border: 1px solid var(--accent);
    padding: 1px 6px;
  }

  .pricing-tokens {
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }

  .pricing-usd {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ink);
  }

  .pricing-mmk {
    font-family: var(--mono);
    font-size: 0.8125rem;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .pricing-header {
      display: none;
    }

    .pricing-row {
      grid-template-columns: 1fr auto;
      gap: 0.5rem;
    }

    .pricing-tier {
      grid-column: 1 / -1;
    }

    .pricing-tokens::before {
      content: 'Tokens: ';
      font-weight: 400;
      color: var(--muted);
      font-size: 0.6875rem;
    }

    .pricing-usd::before {
      content: 'USD: ';
      font-weight: 400;
      color: var(--muted);
      font-size: 0.6875rem;
    }

    .pricing-mmk {
      display: none;
    }
  }
</style>
