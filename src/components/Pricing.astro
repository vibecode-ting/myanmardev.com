---
// Pricing section - Token packages
---

<section id="pricing" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-top:1px solid #1D232B">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise" style="justify-content:center"><b></b> <span>/ pricing</span></div>
    <h2 class="h-section rise" style="margin-top:.9rem;text-align:center">How Tokens Work</h2>
    <p class="lede rise" style="margin:.6rem auto 0;text-align:center;max-width:600px">
      Tokens are our universal currency. Buy once, use across all products. No subscriptions, no hidden fees.
    </p>

    <!-- Token Packages -->
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.5rem;margin-top:3rem">
      <!-- Starter -->
      <div class="pricing-card rise" style="padding:2rem;background:var(--wash);border:1px solid #1D232B;border-radius:12px;text-align:center">
        <div style="font-family:var(--mono);font-size:0.75rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">
          Starter
        </div>
        <div style="font-family:var(--display);font-size:2.5rem;font-weight:700;color:var(--ink);margin-bottom:0.25rem">
          5
        </div>
        <div style="font-family:var(--mono);font-size:0.875rem;color:var(--muted);margin-bottom:1.5rem">
          Tokens
        </div>
        <div style="font-family:var(--display);font-size:1.5rem;font-weight:700;color:var(--accent);margin-bottom:0.25rem">
          $2.50
        </div>
        <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1.5rem">
          USD
        </div>
        <div style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);line-height:1.5">
          Perfect for trying out. Get 5 subdomains or mix and match with other products.
        </div>
      </div>

      <!-- Basic -->
      <div class="pricing-card rise" style="padding:2rem;background:var(--wash);border:1px solid #1D232B;border-radius:12px;text-align:center">
        <div style="font-family:var(--mono);font-size:0.75rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">
          Basic
        </div>
        <div style="font-family:var(--display);font-size:2.5rem;font-weight:700;color:var(--ink);margin-bottom:0.25rem">
          10
        </div>
        <div style="font-family:var(--mono);font-size:0.875rem;color:var(--muted);margin-bottom:1.5rem">
          Tokens
        </div>
        <div style="font-family:var(--display);font-size:1.5rem;font-weight:700;color:var(--accent);margin-bottom:0.25rem">
          $4.00
        </div>
        <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1.5rem">
          USD
        </div>
        <div style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);line-height:1.5">
          Great for small projects. Enough for 10 subdomains or a few websites.
        </div>
      </div>

      <!-- Pro (Popular) -->
      <div class="pricing-card rise" style="padding:2rem;background:var(--wash);border:2px solid var(--accent);border-radius:12px;text-align:center;position:relative">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--accent);color:var(--base);font-family:var(--mono);font-size:0.6875rem;font-weight:700;padding:4px 12px;border-radius:12px;text-transform:uppercase;letter-spacing:0.05em">
          Popular
        </div>
        <div style="font-family:var(--mono);font-size:0.75rem;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">
          Pro
        </div>
        <div style="font-family:var(--display);font-size:2.5rem;font-weight:700;color:var(--ink);margin-bottom:0.25rem">
          25
        </div>
        <div style="font-family:var(--mono);font-size:0.875rem;color:var(--muted);margin-bottom:1.5rem">
          Tokens
        </div>
        <div style="font-family:var(--display);font-size:1.5rem;font-weight:700;color:var(--accent);margin-bottom:0.25rem">
          $8.00
        </div>
        <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1.5rem">
          USD
        </div>
        <div style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);line-height:1.5">
          Best value for developers. Build multiple projects and portfolios.
        </div>
      </div>

      <!-- Business -->
      <div class="pricing-card rise" style="padding:2rem;background:var(--wash);border:1px solid #1D232B;border-radius:12px;text-align:center">
        <div style="font-family:var(--mono);font-size:0.75rem;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">
          Business
        </div>
        <div style="font-family:var(--display);font-size:2.5rem;font-weight:700;color:var(--ink);margin-bottom:0.25rem">
          50
        </div>
        <div style="font-family:var(--mono);font-size:0.875rem;color:var(--muted);margin-bottom:1.5rem">
          Tokens
        </div>
        <div style="font-family:var(--display);font-size:1.5rem;font-weight:700;color:var(--accent);margin-bottom:0.25rem">
          $12.00
        </div>
        <div style="font-family:var(--mono);font-size:0.75rem;color:var(--muted);margin-bottom:1.5rem">
          USD
        </div>
        <div style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);line-height:1.5">
          For agencies and teams. Deploy multiple client projects with ease.
        </div>
      </div>
    </div>

    <!-- How Tokens Work -->
    <div style="margin-top:4rem;padding:2rem;background:var(--wash);border:1px solid #1D232B;border-radius:12px">
      <h3 style="font-family:var(--display);font-size:1.25rem;font-weight:700;color:var(--ink);margin:0 0 1.5rem;text-align:center">
        How Tokens Work
      </h3>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:2rem">
        <div style="text-align:center">
          <div style="font-size:2rem;margin-bottom:0.75rem">1️⃣</div>
          <h4 style="font-family:var(--mono);font-size:0.875rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem">
            Buy Tokens
          </h4>
          <p style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);margin:0;line-height:1.5">
            Purchase token packages above. Request will be reviewed by admin.
          </p>
        </div>
        <div style="text-align:center">
          <div style="font-size:2rem;margin-bottom:0.75rem">2️⃣</div>
          <h4 style="font-family:var(--mono);font-size:0.875rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem">
            Choose Product
          </h4>
          <p style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);margin:0;line-height:1.5">
            Browse our products and select what you need. Each product has a token cost.
          </p>
        </div>
        <div style="text-align:center">
          <div style="font-size:2rem;margin-bottom:0.75rem">3️⃣</div>
          <h4 style="font-family:var(--mono);font-size:0.875rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem">
            Deploy Instantly
          </h4>
          <p style="font-family:var(--body);font-size:0.8125rem;color:var(--muted);margin:0;line-height:1.5">
            Tokens are deducted automatically. Your project deploys in seconds.
          </p>
        </div>
      </div>
    </div>

    <!-- Redeem Codes -->
    <div style="margin-top:2rem;padding:2rem;background:color-mix(in srgb, var(--accent) 8%, transparent);border:1px solid color-mix(in srgb, var(--accent) 20%, transparent);border-radius:12px;text-align:center">
      <div style="font-size:1.5rem;margin-bottom:0.75rem">🎟️</div>
      <h3 style="font-family:var(--display);font-size:1.125rem;font-weight:700;color:var(--ink);margin:0 0 0.5rem">
        Have a Promo Code?
      </h3>
      <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0 0 1rem">
        Sign in and redeem your code for free tokens. No credit card required.
      </p>
      <a href="#" class="btn btn--ghost" style="padding:0.75rem 1.5rem" onclick="document.querySelector('[data-redeem-button]')?.click()">
        Redeem Code
      </a>
    </div>
  </div>
</section>

<style>
  .pricing-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }
</style>
