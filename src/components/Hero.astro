---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section style="padding:clamp(3.5rem,10vh,6rem) clamp(1.25rem,4vw,3rem);max-width:78rem;margin:0 auto" id="hero">
  <p class="eyebrow rise"><span class="dot"></span> {t(lang, 'hero.eyebrow')}</p>

  <h1 class="h-display rise" style="margin-top:1.4rem;max-width:42rem">
    {t(lang, 'hero.heading')}
  </h1>

  <div class="rise" style="width:clamp(4rem,10vw,7rem);height:2px;background:var(--accent);margin-top:1.25rem"></div>

  <p class="lede rise" style="margin-top:1.5rem;max-width:36rem">
    {t(lang, 'hero.lede')}
  </p>

  <div class="rise" style="display:flex;flex-wrap:wrap;gap:.9rem;margin-top:1.9rem">
    <a class="btn" href="#product" style="padding:1rem 2rem">{t(lang, 'hero.cta')}</a>
    <a class="btn btn--ghost" href="#how" style="padding:1rem 2rem">{t(lang, 'hero.how')}</a>
  </div>
  <p class="mono rise" style="color:var(--muted);margin-top:1.4rem">{t(lang, 'hero.footnote')}</p>
</section>
