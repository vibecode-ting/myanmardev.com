---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-bg">
    <img src="/images/hero/hero-bg.svg" alt="" aria-hidden="true" loading="eager" />
  </div>
  <div class="hero-inner">
    <div class="hero-content">
      <div class="hero-text">
        <h1 class="h-display rise">{t(lang, 'hero.heading')}</h1>
        <div class="hero-rule rise"></div>
        <p class="lede rise" style="margin-top:1rem">{t(lang, 'hero.sub')}</p>

        <div class="rise" style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.5rem">
          <a class="btn" href="#products">{t(lang, 'hero.cta')}</a>
          <a class="btn btn--ghost" href="#pricing">{t(lang, 'hero.see')}</a>
        </div>
      </div>
      <div class="hero-visual rise">
        <img src="/images/dns.png" alt="DNS automation illustration" class="hero-dns-img" />
      </div>
    </div>

    <div class="hero-terminal rise">
      <div class="term">
        <div class="bar">
          <span style="font-family:var(--mono);font-size:0.625rem;color:var(--muted);letter-spacing:0.14em;text-transform:uppercase">terminal</span>
        </div>
        <pre><span class="c">$</span> <span class="g">myanmardev</span> deploy <span class="y">--subdomain</span> yourname
<span class="c">→</span> DNS check... <span class="g">available ✓</span>
<span class="c">→</span> SSL provision... <span class="g">done ✓</span>
<span class="c">→</span> Propagating... <span class="g">live ✓</span>
<span class="c">→</span> <span class="g">yourname.myanmardev.com</span> <span class="c">(30s)</span></pre>
      </div>
    </div>

    <!-- Trust signals -->
    <div class="trust-row rise">
      <div class="trust-item">
        <img src="/images/icons/trust-instant.svg" alt="" width="20" height="20" />
        <span>Instant Setup</span>
      </div>
      <div class="trust-item">
        <img src="/images/icons/trust-secure.svg" alt="" width="20" height="20" />
        <span>SSL Secured</span>
      </div>
      <div class="trust-item">
        <img src="/images/icons/trust-automated.svg" alt="" width="20" height="20" />
        <span>Fully Automated</span>
      </div>
      <div class="trust-item">
        <img src="/images/icons/trust-nocard.svg" alt="" width="20" height="20" />
        <span>No Card Needed</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: clamp(4rem, 12vh, 7rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid var(--rule);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.06;
    pointer-events: none;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 78rem;
    margin: 0 auto;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-dns-img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--rule);
    border-radius: 4px;
  }

  .hero-rule {
    width: clamp(3rem, 8vw, 5rem);
    height: 1px;
    background: var(--accent);
    margin-top: 1rem;
  }

  .hero-terminal {
    margin-top: 2rem;
    max-width: 580px;
  }

  .hero-terminal .term {
    border: 1px solid var(--rule);
  }

  .hero-terminal .term .bar {
    border-bottom: 1px solid var(--rule);
    padding: 0.625rem 1rem;
  }

  .hero-terminal .term pre {
    font-size: 0.75rem;
    line-height: 1.9;
    padding: 1rem;
    background: var(--ink);
    color: color-mix(in srgb, var(--base) 80%, transparent);
  }

  .hero-terminal .term .c { color: var(--muted); }
  .hero-terminal .term .g { color: var(--accent); }
  .hero-terminal .term .y { color: #f59e0b; }

  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .trust-item img {
    display: block;
    width: 20px;
    height: 20px;
  }

  @media (max-width: 640px) {
    .hero-content {
      grid-template-columns: 1fr;
    }

    .hero-visual {
      order: -1;
    }

    .trust-row {
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .hero-terminal .term pre {
      font-size: 0.625rem;
      padding: 0.75rem;
    }
  }
</style>
