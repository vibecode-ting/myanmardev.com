---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero-inner">
    <p class="eyebrow rise">{t(lang, 'hero.eyebrow')}</p>

    <h1 class="h-display rise" style="margin-top:1rem;max-width:38rem">
      {t(lang, 'hero.heading')}
    </h1>

    <div class="hero-rule rise"></div>

    <div class="hero-grid">
      <div class="rise">
        <p class="lede" style="max-width:34rem">
          {t(lang, 'hero.sub')}
        </p>

        <div style="display:flex;flex-wrap:wrap;gap:.75rem;margin-top:1.5rem">
          <a class="btn" href="#products">{t(lang, 'hero.cta')}</a>
          <a class="btn btn--ghost" href="#how">{t(lang, 'hero.see')}</a>
        </div>
      </div>

      <div class="hero-terminal rise">
        <div class="term">
          <div class="bar">
            <span style="font-family:var(--mono);font-size:0.625rem;color:var(--muted);letter-spacing:0.14em;text-transform:uppercase">terminal</span>
          </div>
          <pre><span class="c">$</span> <span class="g">myanmardev</span> deploy <span class="y">--subdomain</span> yourname
<span class="c">→</span> DNS check... <span class="g">available ✓</span>
<span class="c">→</span> SSL provision... <span class="g">done ✓</span>
<span class="c">→</span> Propagating... <span class="g">live ✓</span>
<span class="c">→</span> <span class="g">yourname.myanmardev.com</span> <span class="c">(30s)</span></pre>
        </div>
      </div>
    </div>

    <div class="hero-stats rise">
      <div class="stat-item">
        <span class="stat-label">Deploy time</span>
        <span class="stat-value">30s</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Config required</span>
        <span class="stat-value">Zero</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">SSL</span>
        <span class="stat-value">Free</span>
      </div>
      <div class="stat-item">
        <span class="stat-label">Credit card</span>
        <span class="stat-value">None</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: clamp(4rem, 12vh, 7rem) clamp(1.25rem, 4vw, 3rem);
    border-bottom: 1px solid var(--rule);
  }

  .hero-inner {
    max-width: 78rem;
    margin: 0 auto;
  }

  .hero-rule {
    width: clamp(3rem, 8vw, 5rem);
    height: 1px;
    background: var(--accent);
    margin-top: 1rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    margin-top: 2rem;
    align-items: start;
  }

  .hero-terminal .term {
    border: 1px solid var(--rule);
  }

  .hero-terminal .term .bar {
    border-bottom: 1px solid var(--rule);
    padding: 0.625rem 1rem;
  }

  .hero-terminal .term pre {
    font-size: 0.75rem;
    line-height: 1.9;
    padding: 1rem;
    background: var(--ink);
    color: color-mix(in srgb, var(--base) 80%, transparent);
  }

  .hero-terminal .term .c { color: var(--muted); }
  .hero-terminal .term .g { color: var(--accent); }
  .hero-terminal .term .y { color: #E8A33D; }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 2.5rem;
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hero-terminal .term pre {
      font-size: 0.625rem;
      padding: 0.75rem;
    }
  }
</style>
