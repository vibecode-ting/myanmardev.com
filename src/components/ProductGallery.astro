---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const products = [
  { key: 'p1', icon: '🌐', href: '/products/subdomain', available: true },
  { key: 'p2', icon: '🏗️', href: null, available: false },
  { key: 'p3', icon: '💼', href: null, available: false },
];
---

<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;margin-top:2.5rem">
  {products.map((product) => (
    <div
      class="product-card rise"
      style={`padding:1.75rem;background:var(--surface);border:1px solid ${product.available ? 'var(--border-accent)' : 'var(--border)'};border-radius:10px;transition:all 0.2s;${product.available ? '' : 'opacity:0.6'}`}
    >
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
        <div style="font-size:2rem">{product.icon}</div>
        <span style={`font-family:var(--mono);font-size:0.625rem;font-weight:600;color:${product.available ? 'var(--accent)' : 'var(--muted)'};background:${product.available ? 'var(--glow)' : 'var(--surface)'};border:1px solid ${product.available ? 'var(--border-accent)' : 'var(--border)'};padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.06em`}>
          {t(lang, `products.${product.key}.status`)}
        </span>
      </div>
      <h3 style="font-family:var(--display);font-size:1.25rem;font-weight:600;color:var(--ink);margin:0 0 0.4rem;letter-spacing:-0.01em">
        {t(lang, `products.${product.key}.name`)}
      </h3>
      <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0 0 1.25rem;line-height:1.6">
        {t(lang, `products.${product.key}.desc`)}
      </p>
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
        <span style="font-family:var(--mono);font-size:0.8125rem;font-weight:700;color:var(--accent)">
          {t(lang, `products.${product.key}.price`)}
        </span>
      </div>
      {product.available && product.href ? (
        <a href={product.href} class="btn" style="width:100%;justify-content:center;padding:0.7rem">
          {t(lang, 'common.actions.order')}
        </a>
      ) : (
        <button disabled style="width:100%;justify-content:center;padding:0.7rem;background:var(--surface);color:var(--muted);border:1px solid var(--border);border-radius:6px;font-family:var(--mono);font-size:0.75rem;font-weight:600;cursor:not-allowed;text-transform:uppercase;letter-spacing:0.06em">
          {t(lang, `products.${product.key}.status`)}
        </button>
      )}
    </div>
  ))}
</div>

<style>
  .product-card:hover {
    border-color: var(--border-accent) !important;
    transform: translateY(-2px);
    box-shadow: 0 0 24px var(--glow), 0 8px 24px rgba(0,0,0,0.2);
  }
</style>
