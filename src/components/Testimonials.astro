---
import { t, type Language } from '../i18n/utils';
const { lang = 'en' } = Astro.props as { lang: Language };
---

<section id="testimonials" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise"><b></b> <span>{t(lang, 'testimonials.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.75rem">{t(lang, 'testimonials.heading')}</h2>

    <div class="testimonial-rows">
      <div class="testimonial-row rise">
        <p class="testimonial-quote">"{t(lang, 'testimonials.t1/q')}"</p>
        <div class="testimonial-author">
          <span class="testimonial-initial">{t(lang, 'testimonials.t1/a').charAt(0)}</span>
          <div>
            <div class="testimonial-name">{t(lang, 'testimonials.t1/a')}</div>
            <div class="testimonial-role">{t(lang, 'testimonials.t1/role')}</div>
          </div>
        </div>
      </div>

      <div class="testimonial-row rise">
        <p class="testimonial-quote">"{t(lang, 'testimonials.t2/q')}"</p>
        <div class="testimonial-author">
          <span class="testimonial-initial">{t(lang, 'testimonials.t2/a').charAt(0)}</span>
          <div>
            <div class="testimonial-name">{t(lang, 'testimonials.t2/a')}</div>
            <div class="testimonial-role">{t(lang, 'testimonials.t2/role')}</div>
          </div>
        </div>
      </div>

      <div class="testimonial-row rise">
        <p class="testimonial-quote">"{t(lang, 'testimonials.t3/q')}"</p>
        <div class="testimonial-author">
          <span class="testimonial-initial">{t(lang, 'testimonials.t3/a').charAt(0)}</span>
          <div>
            <div class="testimonial-name">{t(lang, 'testimonials.t3/a')}</div>
            <div class="testimonial-role">{t(lang, 'testimonials.t3/role')}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-rows {
    margin-top: 2rem;
  }

  .testimonial-row {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
  }

  .testimonial-row:first-child {
    border-top: 1px solid var(--rule);
  }

  .testimonial-quote {
    font-family: var(--body);
    font-size: 1rem;
    color: var(--ink);
    line-height: 1.75;
    margin: 0 0 1rem;
    max-width: 68ch;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .testimonial-initial {
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    flex-shrink: 0;
  }

  .testimonial-name {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--ink);
  }

  .testimonial-role {
    font-family: var(--body);
    font-size: 0.6875rem;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .testimonial-rows {
      display: flex;
      flex-direction: column;
    }
  }
</style>
