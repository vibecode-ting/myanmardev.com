---
import SubdomainBuilder from './SubdomainBuilder';
---

<section id="product" class="relative py-12 sm:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-fade-in-up">
      <span class="inline-block px-3 py-1 rounded-full bg-purple-50 dark:bg-purple-950/30 border border-purple-200 dark:border-purple-800 text-purple-700 dark:text-purple-300 text-xs font-semibold tracking-wider uppercase mb-3">
        Available Product
      </span>
    </div>

    <!-- Product Card -->
    <div class="relative group animate-fade-in-up" style="animation-delay: 0.2s">
      <!-- Glow effect on hover -->
      <div class="absolute -inset-[2px] rounded-3xl bg-gradient-to-r from-purple-500 via-violet-500 to-indigo-500 opacity-0 group-hover:opacity-30 blur-xl transition-opacity duration-500"></div>

      <!-- Card -->
      <div class="relative rounded-3xl bg-white dark:bg-[#111114] border border-slate-200 dark:border-slate-800 overflow-hidden">
        <!-- Card header -->
        <div class="p-6 sm:p-8 border-b border-slate-100 dark:border-slate-800">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white text-lg shadow-lg shadow-purple-500/20">
              🌐
            </div>
            <div>
              <h2 class="text-xl font-bold text-slate-900 dark:text-white">Subdomain Builder</h2>
              <p class="text-xs text-slate-500 dark:text-slate-400">DNS Automation via Cloudflare</p>
            </div>
          </div>
          <p class="text-slate-600 dark:text-slate-300 text-sm leading-relaxed">
            Get your own <code class="px-1.5 py-0.5 bg-purple-50 dark:bg-purple-950/30 text-purple-600 dark:text-purple-400 rounded text-xs font-mono">.myanmardev.com</code> subdomain in seconds. Our system checks availability and creates the DNS record automatically.
          </p>
        </div>

        <!-- Card body — the builder form -->
        <div class="p-6 sm:p-8">
          <SubdomainBuilder client:load />
        </div>
      </div>
    </div>
  </div>
</section>
