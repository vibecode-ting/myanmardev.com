---
import SubdomainBuilder from './SubdomainBuilder';
---

<section id="product" style="padding:clamp(3rem,7vw,5rem) 0">
  <div style="max-width:78rem;margin:0 auto;padding:0 clamp(1.25rem,4vw,3rem)">
    <div class="sx rise"><b></b> <span>/ product</span></div>
    <h2 class="h-section rise" style="margin-top:.9rem;max-width:32rem">Subdomain Register — live builder</h2>
    <p class="lede rise" style="margin-top:.6rem">Try it now. Enter a subdomain, pick your platform, and see the DNS record preview before you commit.</p>
  </div>

  <div class="rise" style="max-width:78rem;margin:2rem auto 0;padding:0 clamp(1.25rem,4vw,3rem)">
    <div class="panel ticks" style="padding:clamp(1.5rem,3vw,2.5rem)">
      <!-- Panel header -->
      <div class="ph" style="margin:-0.7rem -1rem 1.5rem">
        <span class="mono" style="color:var(--accent);font-weight:700">subdomain.interactive</span>
        <span class="mono" style="color:var(--muted)">live dns builder</span>
      </div>

      <SubdomainBuilder client:load />
    </div>
  </div>
</section>
