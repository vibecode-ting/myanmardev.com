---
import SubdomainBuilder from './SubdomainBuilder';
---

<!-- How It Works mini-section -->
<section class="py-12">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10 animate-fade-in-up">
      <span class="inline-block px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400 text-xs font-semibold tracking-wider uppercase mb-3">
        How It Works
      </span>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-white mb-4 tracking-tight">
        Three simple steps
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-16">
      <div class="group text-center p-6 rounded-2xl bg-white dark:bg-[#0c0c0f] border border-slate-200 dark:border-slate-800 hover:border-purple-500/30 dark:hover:border-purple-500/30 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-purple-500 to-violet-600 flex items-center justify-center text-white text-xl font-extrabold shadow-lg shadow-purple-500/20 group-hover:scale-110 transition-transform duration-300">1</div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-1">Pick a subdomain</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">Choose any available name under myanmardev.com</p>
      </div>
      <div class="group text-center p-6 rounded-2xl bg-white dark:bg-[#0c0c0f] border border-slate-200 dark:border-slate-800 hover:border-purple-500/30 dark:hover:border-purple-500/30 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-violet-500 to-indigo-600 flex items-center justify-center text-white text-xl font-extrabold shadow-lg shadow-violet-500/20 group-hover:scale-110 transition-transform duration-300">2</div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-1">Choose platform</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">Select where your site is hosted</p>
      </div>
      <div class="group text-center p-6 rounded-2xl bg-white dark:bg-[#0c0c0f] border border-slate-200 dark:border-slate-800 hover:border-purple-500/30 dark:hover:border-purple-500/30 hover:shadow-lg transition-all duration-300">
        <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-xl font-extrabold shadow-lg shadow-indigo-500/20 group-hover:scale-110 transition-transform duration-300">3</div>
        <h3 class="font-bold text-slate-900 dark:text-white mb-1">DNS created</h3>
        <p class="text-sm text-slate-500 dark:text-slate-400">We create the Cloudflare DNS record automatically</p>
      </div>
    </div>
  </div>
</section>

<!-- Product Card -->
<section id="product" class="relative py-12 sm:py-16">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 animate-fade-in-up">
      <span class="inline-block px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 text-purple-400 text-xs font-semibold tracking-wider uppercase mb-3">
        Available Product
      </span>
    </div>

    <div class="relative group animate-fade-in-up" style="animation-delay: 0.1s">
      <!-- Glow effect on hover -->
      <div class="absolute -inset-[2px] rounded-3xl bg-gradient-to-r from-purple-500 via-violet-500 to-indigo-500 opacity-0 group-hover:opacity-25 blur-xl transition-opacity duration-500"></div>

      <!-- Card -->
      <div class="relative rounded-3xl bg-white dark:bg-[#08080a] border border-slate-200 dark:border-slate-800 overflow-hidden">
        <!-- Card header -->
        <div class="p-6 sm:p-8 border-b border-slate-100 dark:border-slate-800/50">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-purple-500 to-indigo-600 flex items-center justify-center text-white text-xl shadow-lg shadow-purple-500/20">
              🌐
            </div>
            <div>
              <h2 class="text-xl font-bold text-slate-900 dark:text-white">Subdomain Builder</h2>
              <p class="text-xs text-slate-500 dark:text-slate-400">DNS Automation via Cloudflare API</p>
            </div>
          </div>
          <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed">
            Get your own <code class="px-1.5 py-0.5 bg-purple-500/10 text-purple-400 rounded text-xs font-mono">.myanmardev.com</code> subdomain in seconds. Our system checks DNS availability and creates the CNAME record automatically.
          </p>
        </div>

        <!-- Card body -->
        <div class="p-6 sm:p-8">
          <SubdomainBuilder client:load />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in-up {
    animation: fadeInUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
</style>
