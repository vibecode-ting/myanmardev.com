---
import { t, type Language } from '../i18n/utils';
const { lang = 'en' } = Astro.props as { lang: Language };
---

<section id="cta" style="padding:clamp(4rem,10vw,6rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <h2 class="h-display rise" style="max-width:32rem">{t(lang, 'cta.heading')}</h2>
    <div class="rise" style="width:clamp(3rem,8vw,5rem);height:1px;background:var(--accent);margin-top:1rem"></div>
    <p class="lede rise" style="margin-top:1rem;max-width:40rem">{t(lang, 'cta.sub')}</p>
    <div class="rise" style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.5rem">
      <a href="#pricing" class="btn">{t(lang, 'cta.start')}</a>
      <a href="#pricing" class="btn btn--ghost">{t(lang, 'cta.pricing')}</a>
    </div>
  </div>
</section>
