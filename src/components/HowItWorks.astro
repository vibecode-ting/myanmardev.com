---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="how" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise"><b></b> <span>{t(lang, 'how.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.75rem">{t(lang, 'how.heading')}</h2>

    <div class="how-rows">
      <div class="how-row rise">
        <span class="how-num">01</span>
        <div class="how-content">
          <h3 class="how-title">{t(lang, 'how.s1')}</h3>
          <p class="how-desc">{t(lang, 'how.s1d')}</p>
        </div>
      </div>

      <div class="how-row rise">
        <span class="how-num">02</span>
        <div class="how-content">
          <h3 class="how-title">{t(lang, 'how.s2')}</h3>
          <p class="how-desc">{t(lang, 'how.s2d')}</p>
        </div>
      </div>

      <div class="how-row rise">
        <span class="how-num">03</span>
        <div class="how-content">
          <h3 class="how-title">{t(lang, 'how.s3')}</h3>
          <p class="how-desc">{t(lang, 'how.s3d')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .how-rows {
    margin-top: 2rem;
  }

  .how-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }

  .how-row:first-child {
    border-top: 1px solid var(--rule);
  }

  .how-num {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.14em;
  }

  .how-title {
    font-family: var(--display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 0.25rem;
  }

  .how-desc {
    font-family: var(--body);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.65;
    max-width: 48ch;
  }
</style>
