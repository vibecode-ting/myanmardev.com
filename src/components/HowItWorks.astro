---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="how" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-top:1px solid var(--border);border-bottom:1px solid var(--border);background:var(--surface)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise" style="justify-content:center"><b></b> <span>{t(lang, 'how.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.9rem;text-align:center">{t(lang, 'how.heading')}</h2>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.25rem;margin-top:2.5rem">
      <!-- Step 1 -->
      <div class="rise how-card">
        <div class="how-step-num">01</div>
        <h3 style="font-family:var(--display);font-size:1.125rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem;letter-spacing:-0.01em">
          {t(lang, 'how.s1')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0;line-height:1.6">
          {t(lang, 'how.s1d')}
        </p>
      </div>

      <!-- Step 2 -->
      <div class="rise how-card">
        <div class="how-step-num">02</div>
        <h3 style="font-family:var(--display);font-size:1.125rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem;letter-spacing:-0.01em">
          {t(lang, 'how.s2')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0;line-height:1.6">
          {t(lang, 'how.s2d')}
        </p>
      </div>

      <!-- Step 3 -->
      <div class="rise how-card">
        <div class="how-step-num">03</div>
        <h3 style="font-family:var(--display);font-size:1.125rem;font-weight:600;color:var(--ink);margin:0 0 0.5rem;letter-spacing:-0.01em">
          {t(lang, 'how.s3')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0;line-height:1.6">
          {t(lang, 'how.s3d')}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .how-card {
    padding: 1.75rem;
    background: var(--base);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .how-card:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 24px var(--glow);
  }

  .how-step-num {
    font-family: var(--mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.75rem;
    letter-spacing: 0.04em;
  }
</style>
