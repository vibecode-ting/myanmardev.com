---
import { t, type Language } from '../i18n/utils';
import SubdomainBuilder from './SubdomainBuilder';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="products" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-top:1px solid var(--border)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise" style="justify-content:center"><b></b> <span>{t(lang, 'products.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.9rem;text-align:center">{t(lang, 'products.heading')}</h2>
    <p class="lede rise" style="margin:.6rem auto 0;text-align:center;max-width:600px">
      {t(lang, 'products.sub')}
    </p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;margin-top:2.5rem">
      <!-- Product 1: Subdomain Registration -->
      <div class="product-card rise" style="padding:1.75rem;background:var(--surface);border:1px solid var(--border-accent);border-radius:10px;position:relative">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <div style="font-size:2rem">🌐</div>
          <span style="font-family:var(--mono);font-size:0.625rem;font-weight:600;color:var(--accent);background:var(--glow);border:1px solid var(--border-accent);padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.06em">{t(lang, 'products.p1.status')}</span>
        </div>
        <h3 style="font-family:var(--display);font-size:1.25rem;font-weight:600;color:var(--ink);margin:0 0 0.4rem;letter-spacing:-0.01em">
          {t(lang, 'products.p1.name')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0 0 1.25rem;line-height:1.6">
          {t(lang, 'products.p1.desc')}
        </p>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
          <span style="font-family:var(--mono);font-size:0.8125rem;font-weight:700;color:var(--accent)">
            {t(lang, 'products.p1.price')}
          </span>
        </div>
        <a href="/products/subdomain" class="btn" style="width:100%;justify-content:center;padding:0.7rem">
          {t(lang, 'common.actions.order')}
        </a>
      </div>

      <!-- Product 2: Static Website Builder -->
      <div class="product-card rise" style="padding:1.75rem;background:var(--surface);border:1px solid var(--border);border-radius:10px;opacity:0.6">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <div style="font-size:2rem">🏗️</div>
          <span style="font-family:var(--mono);font-size:0.625rem;font-weight:600;color:var(--muted);background:var(--wash);border:1px solid var(--border);padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.06em">{t(lang, 'products.p2.status')}</span>
        </div>
        <h3 style="font-family:var(--display);font-size:1.25rem;font-weight:600;color:var(--ink);margin:0 0 0.4rem;letter-spacing:-0.01em">
          {t(lang, 'products.p2.name')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0 0 1.25rem;line-height:1.6">
          {t(lang, 'products.p2.desc')}
        </p>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
          <span style="font-family:var(--mono);font-size:0.8125rem;font-weight:700;color:var(--muted)">
            {t(lang, 'products.p2.price')}
          </span>
        </div>
        <button disabled style="width:100%;justify-content:center;padding:0.7rem;background:var(--wash);color:var(--muted);border:1px solid var(--border);border-radius:6px;font-family:var(--mono);font-size:0.75rem;font-weight:600;cursor:not-allowed;text-transform:uppercase;letter-spacing:0.06em">
          {t(lang, 'products.p2.status')}
        </button>
      </div>

      <!-- Product 3: Developer Portfolio -->
      <div class="product-card rise" style="padding:1.75rem;background:var(--surface);border:1px solid var(--border);border-radius:10px;opacity:0.6">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
          <div style="font-size:2rem">💼</div>
          <span style="font-family:var(--mono);font-size:0.625rem;font-weight:600;color:var(--muted);background:var(--wash);border:1px solid var(--border);padding:3px 8px;border-radius:4px;text-transform:uppercase;letter-spacing:0.06em">{t(lang, 'products.p3.status')}</span>
        </div>
        <h3 style="font-family:var(--display);font-size:1.25rem;font-weight:600;color:var(--ink);margin:0 0 0.4rem;letter-spacing:-0.01em">
          {t(lang, 'products.p3.name')}
        </h3>
        <p style="font-family:var(--body);font-size:0.875rem;color:var(--muted);margin:0 0 1.25rem;line-height:1.6">
          {t(lang, 'products.p3.desc')}
        </p>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem">
          <span style="font-family:var(--mono);font-size:0.8125rem;font-weight:700;color:var(--muted)">
            {t(lang, 'products.p3.price')}
          </span>
        </div>
        <button disabled style="width:100%;justify-content:center;padding:0.7rem;background:var(--wash);color:var(--muted);border:1px solid var(--border);border-radius:6px;font-family:var(--mono);font-size:0.75rem;font-weight:600;cursor:not-allowed;text-transform:uppercase;letter-spacing:0.06em">
          {t(lang, 'products.p3.status')}
        </button>
      </div>
    </div>

    <!-- Interactive SubdomainBuilder (client:load) -->
    <div style="margin-top:3rem">
      <SubdomainBuilder client:load />
    </div>
  </div>
</section>

<style>
  .product-card {
    transition: all 0.2s ease;
  }

  .product-card:hover:not([style*="opacity"]) {
    border-color: var(--border-accent) !important;
    box-shadow: 0 0 24px var(--glow), 0 8px 24px rgba(0,0,0,0.2);
    transform: translateY(-2px);
  }
</style>
