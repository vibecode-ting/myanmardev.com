---
import { t, type Language } from '../i18n/utils';
import SubdomainBuilder from './SubdomainBuilder';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="products" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise"><b></b> <span>{t(lang, 'products.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.75rem">{t(lang, 'products.heading')}</h2>

    <div class="product-rows">
      <!-- Product 1: Subdomain Registration -->
      <a href="/products/subdomain" class="product-row rise">
        <div class="product-row-left">
          <span class="product-status product-status--live">{t(lang, 'products.p1.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p1.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p1.desc')}</p>
        </div>
        <div class="product-row-right">
          <span class="product-price">{t(lang, 'products.p1.price')}</span>
          <span class="product-arrow">→</span>
        </div>
      </a>

      <!-- Product 2: Static Website Builder -->
      <div class="product-row product-row--disabled rise">
        <div class="product-row-left">
          <span class="product-status">{t(lang, 'products.p2.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p2.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p2.desc')}</p>
        </div>
        <div class="product-row-right">
          <span class="product-price product-price--muted">{t(lang, 'products.p2.price')}</span>
        </div>
      </div>

      <!-- Product 3: Developer Portfolio -->
      <div class="product-row product-row--disabled rise">
        <div class="product-row-left">
          <span class="product-status">{t(lang, 'products.p3.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p3.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p3.desc')}</p>
        </div>
        <div class="product-row-right">
          <span class="product-price product-price--muted">{t(lang, 'products.p3.price')}</span>
        </div>
      </div>
    </div>

    <!-- Interactive SubdomainBuilder -->
    <div style="margin-top:3rem">
      <SubdomainBuilder client:load />
    </div>
  </div>
</section>

<style>
  .product-rows {
    margin-top: 2rem;
  }

  .product-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
    cursor: pointer;
  }

  .product-row:first-child {
    border-top: 1px solid var(--rule);
  }

  .product-row:hover:not(.product-row--disabled) {
    background: var(--wash);
  }

  .product-row--disabled {
    opacity: 0.5;
    cursor: default;
  }

  .product-row-left {
    flex: 1;
  }

  .product-row-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .product-status {
    font-family: var(--mono);
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .product-status--live {
    color: var(--accent);
  }

  .product-name {
    font-family: var(--display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0.25rem 0 0.15rem;
  }

  .product-desc {
    font-family: var(--body);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.65;
  }

  .product-price {
    font-family: var(--mono);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
  }

  .product-price--muted {
    color: var(--muted);
  }

  .product-arrow {
    font-family: var(--mono);
    font-size: 1rem;
    color: var(--accent);
    transition: transform 0.15s ease;
  }

  .product-row:hover .product-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .product-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
