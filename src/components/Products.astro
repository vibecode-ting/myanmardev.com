---
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<section id="products" style="padding:clamp(3rem,7vw,5rem) clamp(1.25rem,4vw,3rem);border-bottom:1px solid var(--rule)">
  <div style="max-width:78rem;margin:0 auto">
    <div class="sx rise"><b></b> <span>{t(lang, 'products.section')}</span></div>
    <h2 class="h-section rise" style="margin-top:.75rem">{t(lang, 'products.heading')}</h2>

    <div class="product-gallery">
      <!-- Product 1 -->
      <div class="product-card rise">
        <div class="product-header">
          <span class="product-status product-status--live">{t(lang, 'products.p1.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p1.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p1.desc')}</p>
        </div>
        <div class="product-price-row">
          <span class="product-price">{t(lang, 'products.p1.usd')}</span>
          <span class="product-price-mmk">{t(lang, 'products.p1.mmk')}</span>
        </div>
        <div class="product-actions">
          <a href="/auth/signin" class="btn" style="flex:1;justify-content:center">{t(lang, 'products.p1.order')}</a>
          <button class="btn btn--ghost details-toggle" data-target="details-1" style="flex:1;justify-content:center">{t(lang, 'products.p1.info')}</button>
        </div>
        <div class="product-details" id="details-1">
          <p>{t(lang, 'products.p1.details')}</p>
        </div>
      </div>

      <!-- Product 2 -->
      <div class="product-card rise">
        <div class="product-header">
          <span class="product-status">{t(lang, 'products.p2.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p2.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p2.desc')}</p>
        </div>
        <div class="product-price-row">
          <span class="product-price">{t(lang, 'products.p2.usd')}</span>
          <span class="product-price-mmk">{t(lang, 'products.p2.mmk')}</span>
        </div>
        <div class="product-actions">
          <button class="btn" style="flex:1;justify-content:center;opacity:0.5;cursor:not-allowed" disabled>{t(lang, 'products.p2.order')}</button>
          <button class="btn btn--ghost details-toggle" data-target="details-2" style="flex:1;justify-content:center">{t(lang, 'products.p2.info')}</button>
        </div>
        <div class="product-details" id="details-2">
          <p>{t(lang, 'products.p2.details')}</p>
        </div>
      </div>

      <!-- Product 3 -->
      <div class="product-card rise">
        <div class="product-header">
          <span class="product-status">{t(lang, 'products.p3.status')}</span>
          <h3 class="product-name">{t(lang, 'products.p3.name')}</h3>
          <p class="product-desc">{t(lang, 'products.p3.desc')}</p>
        </div>
        <div class="product-price-row">
          <span class="product-price">{t(lang, 'products.p3.usd')}</span>
          <span class="product-price-mmk">{t(lang, 'products.p3.mmk')}</span>
        </div>
        <div class="product-actions">
          <button class="btn" style="flex:1;justify-content:center;opacity:0.5;cursor:not-allowed" disabled>{t(lang, 'products.p3.order')}</button>
          <button class="btn btn--ghost details-toggle" data-target="details-3" style="flex:1;justify-content:center">{t(lang, 'products.p3.info')}</button>
        </div>
        <div class="product-details" id="details-3">
          <p>{t(lang, 'products.p3.details')}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .product-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    margin-top: 2rem;
    border: 1px solid var(--rule);
    background: var(--rule);
  }

  .product-card {
    background: var(--base);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .product-header {
    flex: 1;
  }

  .product-status {
    font-family: var(--mono);
    font-size: 0.625rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .product-status--live {
    color: var(--accent);
  }

  .product-name {
    font-family: var(--display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0.5rem 0 0.25rem;
  }

  .product-desc {
    font-family: var(--body);
    font-size: 0.875rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.65;
  }

  .product-price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }

  .product-price {
    font-family: var(--mono);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }

  .product-price-mmk {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--muted);
  }

  .product-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .product-details {
    display: none;
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }

  .product-details.open {
    display: block;
  }

  .product-details p {
    font-family: var(--body);
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.75;
    margin: 0;
  }

  @media (max-width: 640px) {
    .product-gallery {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.details-toggle');
    if (!btn) return;
    var target = document.getElementById(btn.dataset.target);
    if (target) {
      target.classList.toggle('open');
      btn.textContent = target.classList.contains('open') ? 'Close' : btn.dataset.label || 'Details';
    }
  });
  // Store original labels
  document.querySelectorAll('.details-toggle').forEach(function (btn) {
    btn.dataset.label = btn.textContent;
  });
</script>
