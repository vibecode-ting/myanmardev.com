---
import AuthButton from './AuthButton';
import TokenBalance from './TokenBalance';
import ThemeToggle from './ThemeToggle.astro';
import { t, type Language } from '../i18n/utils';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
---

<header class="site-header">
  <a href="/" class="logo">
    <img src="/images/logo/myanmardev-icon.svg" alt="myanmardev.com" width="24" height="24" class="logo-icon" />
    <img src="/images/logo/myanmardev-logo.svg" alt="myanmardev.com" class="logo-full" />
    <span class="logo-text"><span style="color:var(--accent)">myanmardev</span>.com</span>
  </a>

  <nav class="desktop-nav" id="tg-links">
    <a href="#hero">{t(lang, 'nav.home')}</a>
    <a href="#products">{t(lang, 'nav.products')}</a>
    <a href="#pricing">{t(lang, 'nav.pricing')}</a>
  </nav>

  <div class="controls">
    <TokenBalance client:load />
    <ThemeToggle />
    <AuthButton client:load />
    <button class="hamburger" id="hamburger-btn" aria-label={t(lang, 'nav.menu')} aria-expanded="false">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="mobile-nav" id="mobile-nav">
    <a href="#hero">{t(lang, 'nav.home')}</a>
    <a href="#products">{t(lang, 'nav.products')}</a>
    <a href="#pricing">{t(lang, 'nav.pricing')}</a>
    <div class="mobile-nav-controls">
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 clamp(1.25rem, 4vw, 3rem);
    background: var(--base);
    border-bottom: 1px solid var(--rule);
    min-height: 3rem;
  }

  .logo {
    font-family: var(--display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    padding: 0.75rem 0;
  }

  .logo-icon {
    display: block;
    width: 24px;
    height: 24px;
  }

  .logo-full {
    display: block;
    height: 24px;
    width: auto;
  }

  .logo-text {
    display: none;
  }

  /* Show text logo when images fail or for fallback */
  .logo-icon[src=""] ~ .logo-text,
  .logo-full[src=""] ~ .logo-text {
    display: inline;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-family: var(--mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .desktop-nav a {
    transition: color 0.15s ease;
    position: relative;
    padding: 0.75rem 0;
  }

  .desktop-nav a:hover {
    color: var(--ink);
  }

  .desktop-nav a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .desktop-nav a:hover::after {
    transform: scaleX(1);
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hamburger {
    display: none;
    background: transparent;
    border: none;
    color: var(--ink);
    cursor: pointer;
    padding: 0.25rem;
  }

  .mobile-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    flex-direction: column;
    gap: 0;
    background: var(--base);
    border-bottom: 1px solid var(--rule);
    padding: 0.5rem 0;
  }

  .mobile-nav a {
    display: block;
    padding: 0.75rem clamp(1.25rem, 4vw, 3rem);
    color: var(--muted);
    text-decoration: none;
    font-family: var(--mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .mobile-nav-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem clamp(1.25rem, 4vw, 3rem);
    border-top: 1px solid var(--rule);
    margin-top: 0.25rem;
  }

  .mobile-nav.open {
    display: flex;
  }

  @media (max-width: 720px) {
    .desktop-nav {
      display: none;
    }

    .hamburger {
      display: inline-flex;
      align-items: center;
    }
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('hamburger-btn');
    var nav = document.getElementById('mobile-nav');
    if (!btn || !nav) return;

    btn.addEventListener('click', function () {
      var isOpen = nav.classList.toggle('open');
      btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    nav.addEventListener('click', function (e) {
      if (e.target.tagName === 'A') {
        nav.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();
</script>
