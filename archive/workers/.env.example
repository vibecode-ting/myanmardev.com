# =============================================================================
# Cloudflare Worker — Subdomain API
# =============================================================================
# This Worker proxies requests to the Cloudflare API for DNS record management.
# It is the ONLY component that holds the Cloudflare API token — the frontend
# never has direct access to it.
#
# Endpoints:
#   GET  /health              — Health check
#   POST /check               — Check subdomain availability
#   POST /create              — Create a DNS CNAME record for a subdomain
#
# The frontend calls this worker via PUBLIC_WORKER_API_URL (set in root .env).
# =============================================================================

# Cloudflare API token
# Scope: Zone -> DNS -> Edit on myanmardev.com only
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here

# Zone ID for myanmardev.com
# Find at: Cloudflare Dashboard -> myanmardev.com -> Overview -> API section
CLOUDFLARE_ZONE_ID=your-zone-id-here

# Allowed origin for CORS requests
# Only this domain can call the worker from a browser
ALLOWED_ORIGIN=https://myanmardev.com
