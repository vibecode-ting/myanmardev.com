# Cloudflare Worker — Subdomain API
# This Worker proxies requests to Cloudflare API for DNS management

# Cloudflare API token (Zone → DNS → Edit)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
# Zone ID for myanmardev.com (find in Cloudflare Dashboard → Overview)
CLOUDFLARE_ZONE_ID=your-zone-id-here
# Allowed origin for CORS (your frontend domain)
ALLOWED_ORIGIN=https://myanmardev.com
